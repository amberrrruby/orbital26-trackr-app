generator client {
  provider = "prisma-client"
  output   = "../lib/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  // FIELDS
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  settings  Json?

  // 1:1 LINKS

  // 1:MANY LINKS
  applications   Application[]
  resumes        Resume[]
  reminders      Reminder[]
  timelineEvents TimelineEvent[]
}

enum Status {
  WISHLIST
  APPLIED
  OA_ASSESSMENT
  INTERVIEW
  OFFER
  REJECTED
}

model Application {
  // FIELDS
  id             String    @id @default(cuid())
  company        String
  role           String
  source         String?
  status         Status    @default(APPLIED)
  interviewRound Int?
  dateApplied    DateTime?
  notes          String?
  tags           String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 1:1 LINKS
  resumeId String?
  resume   Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1:MANY LINKS
  reminders      Reminder[]
  timelineEvents TimelineEvent[]
}

model Resume {
  // FIELDS
  id              String   @id @default(cuid())
  title           String
  tags            String[]
  notes           String?
  filePath        String
  fileType        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  thumbnailPath   String
  thumbnailStatus String // maybe an enum soon

  // 1:1 LINKS
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1:MANY LINKS
  applications Application[]
}

enum ReminderType {
  EVENT
  FOLLOW_UP
}

enum SourceKey {
  DATE_APPLIED
  OA_ASSESSMENT_DATE
  INTERVIEW_DATE
  OFFER_EXPIRY_DATE
}

model Reminder {
  // FIELDS
  id         String       @id @default(cuid())
  type       ReminderType
  remindAt   DateTime
  offsetDays Int?
  content    String?
  source     SourceKey?

  // 1:1 LINKS
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade) // for reminders page

  // 1:MANY LINKS
}

enum TimelineEventType {
  APPLICATION_CREATED
  STATUS_CHANGED
  IMPORTANT_DATE
  REMINDER_COMPLETED
  MANUAL
}

model TimelineEvent {
  // FIELDS
  id          String            @id @default(cuid())
  type        TimelineEventType
  eventDate   DateTime
  description String

  sourceKey SourceKey?
  status    Status?

  // 1:1 LINKS
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade) // maybe? we can remove this later if not needed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
